# ── ChatClaw Configuration ──────────────────────────────────────
#
# Copy this file to .env and modify as needed.
# All variables are runtime — no rebuild needed after changing.

# ── Database ────────────────────────────────────────────────────
# Backend: "drizzle" (server-side SQLite) or "indexeddb" (browser-only)
DB_BACKEND=indexeddb

# Directory for SQLite database file (only used when DB_BACKEND=drizzle)
CHATCLAW_DATA_DIR=./data

# ── Authentication ──────────────────────────────────────────────
# Enable login/registration (requires AUTH_SECRET)
AUTH_ENABLED=false

# Secret for signing JWT tokens (required when auth is enabled)
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── UI ──────────────────────────────────────────────────────────
# Allow multiple companies (set to "false" for single-company mode)
MULTI_COMPANY=true
